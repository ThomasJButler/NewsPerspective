[run]
source = .
omit =
    */venv/*
    */path/to/venv/*
    */tests/*
    */site-packages/*
    */__pycache__/*
    */migrations/*
    setup.py
    test_*.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod

[html]
directory = htmlcov
